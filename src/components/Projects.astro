---
interface Props {
  title: string;
  viewProject: string;
  comingSoon: string;
}

const { title, viewProject, comingSoon } = Astro.props;

const projects = [
  {
    id: "01",
    name: "ram4n.com",
    tech: "Astro, GSAP, Lenis",
    description: "This portfolio — built with scroll-driven animations and multilingual support.",
    url: "https://ram4n.com",
  },
];
---

<section class="projects" id="projects">
  <div class="projects__inner container">
    <div class="projects__label" data-animate="scroll-fade">
      <span class="projects__label-line"></span>
      <span class="projects__label-text">{title}</span>
    </div>

    <div class="projects__list">
      {projects.map((project) => (
        <a
          href={project.url}
          class="projects__item"
          data-animate="scroll-fade"
          target="_blank"
          rel="noopener noreferrer"
        >
          <div class="projects__item-header">
            <span class="projects__item-id">{project.id}</span>
            <span class="projects__item-arrow">&rarr;</span>
          </div>
          <h3 class="projects__item-name">{project.name}</h3>
          <p class="projects__item-desc">{project.description}</p>
          <span class="projects__item-tech">{project.tech}</span>
        </a>
      ))}

      <div class="projects__coming-soon" data-animate="scroll-fade">
        <p>{comingSoon}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .projects__inner {
    display: grid;
    gap: var(--space-lg);
  }

  .projects__label {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .projects__label-line {
    display: block;
    width: 40px;
    height: 1px;
    background: var(--color-accent);
  }

  .projects__label-text {
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
  }

  .projects__list {
    display: grid;
    gap: 1px;
    background: var(--color-border);
  }

  .projects__item {
    display: block;
    padding: var(--space-md) var(--space-md);
    background: var(--color-bg);
    transition: background var(--duration-normal) var(--ease-out);
    position: relative;
    cursor: pointer;
  }

  .projects__item:hover {
    background: var(--color-surface);
  }

  .projects__item:hover .projects__item-arrow {
    transform: translateX(8px);
    opacity: 1;
  }

  .projects__item:hover .projects__item-name {
    color: var(--color-accent);
  }

  .projects__item-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-sm);
  }

  .projects__item-id {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .projects__item-arrow {
    font-size: 1.25rem;
    color: var(--color-accent);
    opacity: 0;
    transform: translateX(0);
    transition: all var(--duration-normal) var(--ease-out);
  }

  .projects__item-name {
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-xs);
    transition: color var(--duration-normal) var(--ease-out);
  }

  .projects__item-desc {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
    max-width: 500px;
  }

  .projects__item-tech {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .projects__coming-soon {
    padding: var(--space-md);
    background: var(--color-bg);
    text-align: center;
    color: var(--color-text-muted);
    font-style: italic;
  }

  [data-animate="scroll-fade"] {
    opacity: 0;
    transform: translateY(40px);
  }
</style>
