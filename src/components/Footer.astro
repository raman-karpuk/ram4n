---
interface Props {
  copyright: string;
}

const { copyright } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner container">
    <span class="footer__copy">&copy; {year} {copyright}</span>
    <span class="footer__brand">ram<span class="footer__accent">4</span>n</span>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-md) 0;
    border-top: 1px solid var(--color-border);
  }

  .footer__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer__copy {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .footer__brand {
    font-size: 0.875rem;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .footer__accent {
    color: var(--color-accent);
  }
</style>
