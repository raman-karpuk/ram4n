---
import "../styles/global.css";
import { type Locale, locales, getLocalePath } from "../i18n";

interface Props {
  title: string;
  description: string;
  locale: Locale;
}

const { title, description, locale } = Astro.props;
const currentPath = "/";
const siteUrl = "https://ram4n.com";

const ogLocaleMap: Record<Locale, string> = {
  en: "en_US",
  ru: "ru_RU",
  pl: "pl_PL",
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Raman" />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <!-- Canonical -->
    <link rel="canonical" href={`${siteUrl}${getLocalePath(locale, currentPath)}`} />

    <!-- Hreflang -->
    {locales.map((loc) => (
      <link
        rel="alternate"
        hreflang={loc}
        href={`${siteUrl}${getLocalePath(loc, currentPath)}`}
      />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`${siteUrl}${getLocalePath(locale, currentPath)}`} />
    <meta property="og:site_name" content="ram4n" />
    <meta property="og:locale" content={ogLocaleMap[locale]} />
    <meta property="og:image" content={`${siteUrl}/og-image.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/og-image.png`} />

    <!-- JSON-LD: Person -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Raman",
      "url": siteUrl,
      "email": "hello@ram4n.com",
      "jobTitle": "Software Developer",
      "sameAs": [
        "https://github.com/vieditcom",
        "https://www.linkedin.com/in/raman-karpuk/"
      ],
      "knowsLanguage": ["en", "ru", "pl"],
      "image": `${siteUrl}/og-image.png`
    })} />
  </head>
  <body>
    <slot />
  </body>
</html>
